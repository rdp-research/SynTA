{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=aspnet-SynTA-913ec635-8f10-4578-b0a2-967da6a83d55;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/synta-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] [{ThreadId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/synta-errors-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "restrictedToMinimumLevel": "Error",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] [{ThreadId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "AI": {
    "Provider": "OpenAI"
  },
  "OpenAI": {
    "ApiKey": "YOUR-API-KEY-HERE",
    "Endpoint": "https://api.openai.com/v1/chat/completions",
    "ModelName": "gpt-5-mini",
    "Temperature": 0.3
  },
  "Gemini": {
    "ApiKey": "YOUR-API-KEY-HERE",
    "ModelName": "gemini-2.5-flash",
    "Temperature": 0.3
  },
  "OpenRouter": {
    "ApiKey": "YOUR-API-KEY-HERE",
    "Endpoint": "https://openrouter.ai/api/v1/chat/completions",
    "Temperature": 0.3,
    "HttpReferer": "",
    "XTitle": "SynTA"
  },
  "Cypress": {
    "NpxPath": "npx",
    "TimeoutSeconds": 300,
    "Headless": false,
    "Browser": "electron",
    "RecordVideo": false,
    "ScreenshotsOnFailure": true,
    "ViewportWidth": 1920,
    "ViewportHeight": 1080
  }
}
