@{
    ViewData["Title"] = "Account Locked";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="alert alert-warning mt-5" role="alert">
            <h2 class="alert-heading"><i class="bi bi-lock-fill"></i> @ViewData["Title"]</h2>
            <hr>
            <p>Your account has been locked by an administrator.</p>
            <p class="mb-0">Please contact support for assistance.</p>
        </div>
    </div>
</div>
