@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="hero">
    <div class="container">
        <h1><i class="bi bi-lightning-charge-fill me-2"></i>SynTA</h1>
        <p class="lead mb-4">Transform your user stories into comprehensive test suites with the power of AI. Generate Gherkin scenarios and Cypress scripts automatically.</p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-area="User" asp-controller="Project" asp-action="Index" class="btn btn-light btn-lg">
                <i class="bi bi-folder2-open me-2"></i>Go to My Projects
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg me-2">
                <i class="bi bi-rocket-takeoff me-2"></i>Get Started Free
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-lg">
                <i class="bi bi-box-arrow-in-right me-2"></i>Log In
            </a>
        }
    </div>
</div>

<!-- Features Section -->
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card card-feature h-100">
            <div class="card-body text-center py-4">
                <div class="card-icon">
                    <i class="bi bi-journal-text text-primary"></i>
                </div>
                <h4 class="card-title mb-3">User Stories</h4>
                <p class="card-text text-muted">Create and manage user stories with acceptance criteria for your projects.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-feature h-100">
            <div class="card-body text-center py-4">
                <div class="card-icon">
                    <i class="bi bi-file-earmark-code text-primary"></i>
                </div>
                <h4 class="card-title mb-3">Gherkin Generation</h4>
                <p class="card-text text-muted">Automatically generate comprehensive test scenarios in Gherkin syntax using AI.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-feature h-100">
            <div class="card-body text-center py-4">
                <div class="card-icon">
                    <i class="bi bi-terminal text-primary"></i>
                </div>
                <h4 class="card-title mb-3">Cypress Scripts</h4>
                <p class="card-text text-muted">Convert Gherkin scenarios into executable Cypress test scripts with AI assistance.</p>
            </div>
        </div>
    </div>
</div>

<!-- How It Works Section -->
<div class="row justify-content-center mb-5">
    <div class="col-lg-10">
        <div class="card">
            <div class="card-header text-center">
                <h3 class="mb-0"><i class="bi bi-diagram-3 me-2 text-primary"></i>How It Works</h3>
            </div>
            <div class="card-body p-4">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="d-flex align-items-start mb-4">
                            <span class="badge bg-primary rounded-circle me-3 p-2" style="min-width: 32px; height: 32px; font-size: 1rem;">1</span>
                            <div>
                                <h5 class="mb-1">Create Projects</h5>
                                <p class="text-muted mb-0">Organize your testing efforts by project.</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-start mb-4">
                            <span class="badge bg-primary rounded-circle me-3 p-2" style="min-width: 32px; height: 32px; font-size: 1rem;">2</span>
                            <div>
                                <h5 class="mb-1">Write User Stories</h5>
                                <p class="text-muted mb-0">Define what needs to be tested with clear acceptance criteria.</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-start">
                            <span class="badge bg-primary rounded-circle me-3 p-2" style="min-width: 32px; height: 32px; font-size: 1rem;">3</span>
                            <div>
                                <h5 class="mb-1">Generate Gherkin</h5>
                                <p class="text-muted mb-0">Let AI create comprehensive test scenarios from your stories.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start mb-4">
                            <span class="badge bg-primary rounded-circle me-3 p-2" style="min-width: 32px; height: 32px; font-size: 1rem;">4</span>
                            <div>
                                <h5 class="mb-1">Review & Edit</h5>
                                <p class="text-muted mb-0">Refine the generated scenarios to match your requirements.</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-start mb-4">
                            <span class="badge bg-primary rounded-circle me-3 p-2" style="min-width: 32px; height: 32px; font-size: 1rem;">5</span>
                            <div>
                                <h5 class="mb-1">Create Cypress Tests</h5>
                                <p class="text-muted mb-0">Automatically convert scenarios into executable test scripts.</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-start">
                            <span class="badge bg-primary rounded-circle me-3 p-2" style="min-width: 32px; height: 32px; font-size: 1rem;">6</span>
                            <div>
                                <h5 class="mb-1">Export & Run</h5>
                                <p class="text-muted mb-0">Download your tests and integrate them into your CI/CD pipeline.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (User.Identity?.IsAuthenticated != true)
{
    <!-- CTA Section -->
    <div class="card bg-gradient-primary text-white text-center">
        <div class="card-body py-5">
            <h3 class="mb-3">Ready to automate your testing?</h3>
            <p class="mb-4 opacity-75">Join SynTA today and start generating professional test suites in minutes.</p>
            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg me-2">
                <i class="bi bi-person-plus me-2"></i>Create Free Account
            </a>
        </div>
    </div>
}
