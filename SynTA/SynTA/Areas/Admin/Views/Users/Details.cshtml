@model UserDetailViewModel
@{
    ViewData["Title"] = "User Details";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-speedometer2 me-1"></i>Admin Dashboard
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-action="Index">Users</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Email</li>
    </ol>
</nav>

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-person me-2"></i>User Details</h1>
        <p class="page-subtitle mb-0">@Model.Email</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Users
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-person-badge me-2 text-primary"></i>User Information</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-sm-4">
                        <small class="text-muted text-uppercase fw-semibold">Email</small>
                    </div>
                    <div class="col-sm-8">
                        @Model.Email
                        @if (Model.EmailConfirmed)
                        {
                            <span class="badge bg-success ms-2">Confirmed</span>
                        }
                        else
                        {
                            <span class="badge bg-warning ms-2">Not Confirmed</span>
                        }
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4">
                        <small class="text-muted text-uppercase fw-semibold">Username</small>
                    </div>
                    <div class="col-sm-8">@(Model.UserName ?? "N/A")</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4">
                        <small class="text-muted text-uppercase fw-semibold">User ID</small>
                    </div>
                    <div class="col-sm-8"><code>@Model.Id</code></div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4">
                        <small class="text-muted text-uppercase fw-semibold">Role</small>
                    </div>
                    <div class="col-sm-8">
                        @if (Model.IsAdmin)
                        {
                            <span class="badge bg-primary">Administrator</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">User</span>
                        }
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4">
                        <small class="text-muted text-uppercase fw-semibold">Account Status</small>
                    </div>
                    <div class="col-sm-8">
                        @if (Model.LockoutEnd.HasValue && Model.LockoutEnd > DateTimeOffset.UtcNow)
                        {
                            <span class="badge bg-danger">Locked Out</span>
                            <br />
                            <small class="text-muted">Until @Model.LockoutEnd.Value.ToLocalTime().ToString("MMMM dd, yyyy")</small>
                        }
                        else
                        {
                            <span class="badge bg-success">Active</span>
                        }
                    </div>
                </div>
                @if (Model.LastActivity.HasValue)
                {
                    <div class="row">
                        <div class="col-sm-4">
                            <small class="text-muted text-uppercase fw-semibold">Last Activity</small>
                        </div>
                        <div class="col-sm-8">@Model.LastActivity.Value.ToLocalTime().ToString("MMMM dd, yyyy HH:mm")</div>
                    </div>
                }
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-graph-up me-2 text-success"></i>Activity Statistics</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-6 col-md-3 mb-3">
                        <div class="stat-card p-3 rounded" style="background: var(--surface-secondary);">
                            <h3 class="mb-1" style="color: var(--accent-primary);">@Model.ProjectCount</h3>
                            <small class="text-muted">Projects</small>
                        </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                        <div class="stat-card p-3 rounded" style="background: var(--surface-secondary);">
                            <h3 class="mb-1" style="color: var(--accent-amber);">@Model.UserStoryCount</h3>
                            <small class="text-muted">User Stories</small>
                        </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                        <div class="stat-card p-3 rounded" style="background: var(--surface-secondary);">
                            <h3 class="mb-1" style="color: var(--accent-emerald);">@Model.GherkinScenarioCount</h3>
                            <small class="text-muted">Gherkin</small>
                        </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                        <div class="stat-card p-3 rounded" style="background: var(--surface-secondary);">
                            <h3 class="mb-1" style="color: var(--accent-cyan);">@Model.CypressScriptCount</h3>
                            <small class="text-muted">Cypress</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.Projects.Any())
        {
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-folder2 me-2 text-warning"></i>Projects (@Model.Projects.Count)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Project Name</th>
                                    <th class="text-center">User Stories</th>
                                    <th>Created</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var project in Model.Projects)
                                {
                                    <tr>
                                        <td class="fw-semibold">@project.Name</td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary">@project.UserStoryCount</span>
                                        </td>
                                        <td class="text-muted small">@project.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-shield-check me-2 text-danger"></i>Admin Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    @if (Model.LockoutEnd.HasValue && Model.LockoutEnd > DateTimeOffset.UtcNow)
                    {
                        <form asp-action="ToggleLockout" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-success w-100">
                                <i class="bi bi-unlock me-1"></i> Unlock Account
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="ToggleLockout" asp-route-id="@Model.Id" method="post" 
                              onsubmit="return confirm('Are you sure you want to lock this user account?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-warning w-100">
                                <i class="bi bi-lock me-1"></i> Lock Account
                            </button>
                        </form>
                    }

                    @if (Model.IsAdmin)
                    {
                        <form asp-action="ToggleAdmin" asp-route-id="@Model.Id" method="post"
                              onsubmit="return confirm('Are you sure you want to remove admin privileges from this user?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-person-dash me-1"></i> Remove Admin Role
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="ToggleAdmin" asp-route-id="@Model.Id" method="post"
                              onsubmit="return confirm('Are you sure you want to grant admin privileges to this user?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-person-plus me-1"></i> Grant Admin Role
                            </button>
                        </form>
                    }

                    <hr />

                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Are you sure you want to permanently delete this user and all their data? This action cannot be undone.');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger w-100">
                            <i class="bi bi-trash me-1"></i> Delete User
                        </button>
                    </form>
                </div>
            </div>
            <div class="card-footer">
                <small class="text-muted">
                    <i class="bi bi-exclamation-triangle me-1"></i> 
                    Admin actions are permanent and cannot be undone.
                </small>
            </div>
        </div>
    </div>
</div>
