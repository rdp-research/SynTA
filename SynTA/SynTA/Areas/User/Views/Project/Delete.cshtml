@model ProjectViewModel
@{
    ViewData["Title"] = "Delete Project";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="page-header">
            <div>
                <h1 class="page-title" style="color: var(--accent-rose);"><i class="bi bi-trash me-2"></i>Delete Project</h1>
                <p class="page-subtitle mb-0">This action cannot be undone</p>
            </div>
        </div>
        
        <div class="alert alert-danger" role="alert">
            <h5 class="alert-heading"><i class="bi bi-exclamation-triangle me-2"></i>Warning!</h5>
            <p class="mb-0">Are you sure you want to delete this project permanently?</p>
            @if (Model.UserStoryCount > 0)
            {
                <hr>
                <p class="mb-0">
                    <strong>Note:</strong> This project contains <strong>@Model.UserStoryCount</strong> user @(Model.UserStoryCount == 1 ? "story" : "stories") 
                    which will also be permanently deleted along with all associated Gherkin scenarios and Cypress scripts.
                </p>
            }
        </div>
        
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-info-circle me-2 text-primary"></i>Project Details</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-sm-4">
                        <small class="text-muted text-uppercase fw-semibold">Project Name</small>
                    </div>
                    <div class="col-sm-8 fw-semibold">@Model.Name</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4">
                        <small class="text-muted text-uppercase fw-semibold">Description</small>
                    </div>
                    <div class="col-sm-8">@(Model.Description ?? "No description")</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4">
                        <small class="text-muted text-uppercase fw-semibold">Created</small>
                    </div>
                    <div class="col-sm-8">@Model.CreatedAt.ToString("MMMM dd, yyyy")</div>
                </div>
                <div class="row mb-4">
                    <div class="col-sm-4">
                        <small class="text-muted text-uppercase fw-semibold">User Stories</small>
                    </div>
                    <div class="col-sm-8">
                        <span class="badge bg-primary">@Model.UserStoryCount</span>
                    </div>
                </div>
                
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-between pt-3 border-top">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i> Delete Project
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
