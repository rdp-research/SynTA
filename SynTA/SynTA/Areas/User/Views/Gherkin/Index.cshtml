@model IEnumerable<GherkinEditorViewModel>
@{
    ViewData["Title"] = "Gherkin Scenarios";
    var userStoryId = ViewBag.UserStoryId;
    var userStoryTitle = ViewBag.UserStoryTitle;
    var projectName = ViewBag.ProjectName;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="User" asp-controller="Project" asp-action="Index">
                <i class="bi bi-folder2-open me-1"></i>My Projects
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-area="User" asp-controller="UserStory" asp-action="Details" asp-route-id="@userStoryId">@userStoryTitle</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Gherkin Scenarios</li>
    </ol>
</nav>

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-file-earmark-code me-2"></i>Gherkin Scenarios</h1>
        <p class="page-subtitle mb-0">User Story: <strong>@userStoryTitle</strong></p>
    </div>
    <div class="page-actions">
        @if (Model.Any())
        {
            <form asp-action="DeleteAll" asp-route-userStoryId="@userStoryId" method="post" class="d-inline"
                  onsubmit="return confirm('Are you sure you want to delete ALL Gherkin scenarios? This action cannot be undone.');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-1"></i> Delete All
                </button>
            </form>
        }
        <a asp-action="Generate" asp-route-userStoryId="@userStoryId" class="btn btn-success">
            <i class="bi bi-magic me-1"></i> Generate New
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">
            <i class="bi bi-file-earmark-code"></i>
        </div>
        <h3>No Gherkin Scenarios Yet</h3>
        <p>Generate test scenarios from your user story using AI!</p>
        <a asp-action="Generate" asp-route-userStoryId="@userStoryId" class="btn btn-success btn-lg">
            <i class="bi bi-magic me-2"></i>Generate Gherkin Scenarios
        </a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var scenario in Model)
        {
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-file-earmark-text me-2 text-primary"></i>@scenario.Title
                        </h5>
                    </div>
                    <div class="card-body">
                        <pre class="gherkin-content font-monospace mb-3">@scenario.Content</pre>
                        
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">
                                <i class="bi bi-clock me-1"></i>
                                Created: @scenario.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy 'at' h:mm tt")
                                @if (scenario.UpdatedAt.HasValue)
                                {
                                    <span class="ms-2">| Updated: @scenario.UpdatedAt.Value.ToLocalTime().ToString("MMM dd, yyyy 'at' h:mm tt")</span>
                                }
                            </small>
                            
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@scenario.Id" class="btn btn-primary btn-sm">
                                    <i class="bi bi-pencil me-1"></i> Edit
                                </a>
                                <a asp-area="User" asp-controller="Cypress" asp-action="Configure" asp-route-gherkinScenarioId="@scenario.Id" 
                                   class="btn btn-info btn-sm">
                                    <i class="bi bi-code-slash me-1"></i> Generate Cypress
                                </a>
                                <form asp-action="Delete" asp-route-id="@scenario.Id" method="post" class="d-inline" 
                                      onsubmit="return confirm('Are you sure you want to delete this scenario?');">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
