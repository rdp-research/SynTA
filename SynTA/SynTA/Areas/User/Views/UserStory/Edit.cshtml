@model UserStoryCreateViewModel
@{
    ViewData["Title"] = "Edit User Story";
    var userStoryId = ViewBag.UserStoryId;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="User" asp-controller="Project" asp-action="Index">
                <i class="bi bi-folder2-open me-1"></i>My Projects
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-area="User" asp-controller="UserStory" asp-action="Index" asp-route-projectId="@Model.ProjectId">@Model.ProjectName</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Edit</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="page-header">
            <div>
                <h1 class="page-title"><i class="bi bi-pencil me-2"></i>Edit User Story</h1>
                <p class="page-subtitle mb-0">Update user story details</p>
            </div>
        </div>
        
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="Edit" asp-route-id="@userStoryId" method="post">
                    <input type="hidden" asp-for="ProjectId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label">
                            <i class="bi bi-type me-1"></i> Title
                        </label>
                        <input asp-for="Title" class="form-control form-control-lg" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                        <div class="form-text">
                            A short title for organization and file naming.
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="UserStoryText" class="form-label">
                            <i class="bi bi-chat-left-text me-1"></i> User Story
                        </label>
                        <textarea asp-for="UserStoryText" class="form-control" rows="3" 
                                  placeholder="e.g., As a user, I want to login to my account so that I can access my personal dashboard"></textarea>
                        <span asp-validation-for="UserStoryText" class="text-danger small"></span>
                        <div class="form-text">
                            The user story in standard format. This will be passed to the AI for test generation.
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label">
                            <i class="bi bi-text-paragraph me-1"></i> Description <span class="text-muted fw-normal">(Optional)</span>
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                        <div class="form-text">
                            Additional context to help the AI generate better test scenarios.
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="AcceptanceCriteria" class="form-label">
                            <i class="bi bi-list-check me-1"></i> Acceptance Criteria
                        </label>
                        <textarea asp-for="AcceptanceCriteria" class="form-control" rows="5" 
                                  placeholder="Example:&#10;- User can successfully login with valid credentials&#10;- Error message displayed for invalid password&#10;- Account locked after 3 failed attempts"></textarea>
                        <span asp-validation-for="AcceptanceCriteria" class="text-danger small"></span>
                        <div class="form-text">
                            Define conditions that must be met. Use any format: bullet points, numbered list, or Given-When-Then.
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-between pt-3 border-top">
                        <a asp-action="Index" asp-route-projectId="@Model.ProjectId" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
