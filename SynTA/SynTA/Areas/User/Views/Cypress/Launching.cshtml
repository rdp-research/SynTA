@{
    ViewData["Title"] = "Launching Cypress";
    Layout = "_Layout";
}

<div class="launch-container">
    <div class="launch-card">
        <div class="launch-spinner"></div>
        <h2>Launching Cypress</h2>
        <p id="statusText">Initializing test runner...</p>
    </div>
</div>

<style>
    .launch-container {
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .launch-card {
        text-align: center;
        padding: 3rem;
    }
    
    .launch-spinner {
        width: 48px;
        height: 48px;
        border: 4px solid var(--border-color, #e2e8f0);
        border-top-color: var(--primary, #3b82f6);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 1.5rem;
    }
    
    .launch-card h2 {
        color: var(--text-primary, #1e293b);
        margin-bottom: 0.5rem;
        font-weight: 600;
    }
    
    .launch-card p {
        color: var(--text-secondary, #64748b);
        margin: 0;
    }
    
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

@section Scripts {
<script>
(function() {
    const runId = '@ViewBag.RunId';
    const scriptId = '@ViewBag.ScriptId';
    const statusUrl = '@Url.Action("GetRunStatus", "Cypress", new { area = "User" })';
    const returnUrl = '@Url.Action("ReviewAndExport", "Cypress", new { area = "User", id = ViewBag.ScriptId, testLaunched = true })';
    
    const statusText = document.getElementById('statusText');
    let pollCount = 0;
    
    async function checkStatus() {
        pollCount++;
        
        try {
            const res = await fetch(`${statusUrl}?runId=${runId}`);
            if (!res.ok) throw new Error('Status check failed');
            
            const data = await res.json();
            
            // State: 0=NotStarted, 1=Initializing, 2=Running, 3=Completed, 4=Failed
            
            if (data.state === 1) { // Initializing
                statusText.textContent = 'Starting Cypress environment...';
                 if (pollCount > 10) {
                     statusText.textContent = 'Opening browser...';
                 }
            }
            else if (data.state >= 2) { // Running or Completed
                // Cypress is strictly running or finished - redirect back
                statusText.textContent = 'Tests are running!';
                setTimeout(() => {
                    window.location.href = returnUrl;
                }, 500); // Slight delay to let user see "Tests are running!"
                return;
            }
            else if (data.state === 4) { // Failed
                 statusText.textContent = 'Test run failed to start.';
                 statusText.style.color = '#ef4444';
                 setTimeout(() => {
                     // Redirect back to show error
                      window.location.href = returnUrl.replace('testLaunched=true', 'testLaunched=false');
                 }, 2000);
                 return;
            }
            
            // Keep polling (max 60 seconds - bumped up as startup can be slow)
            if (pollCount < 120) {
                setTimeout(checkStatus, 500);
            } else {
                // Timeout - redirect anyway
                window.location.href = returnUrl;
            }
        } catch (err) {
            console.error('Poll error:', err);
            // On error, redirect back
            window.location.href = returnUrl;
        }
    }
    
    // Start polling immediately
    checkStatus();
})();
</script>
}
