@model CypressReviewViewModel
@{
    ViewData["Title"] = "Review & Export Cypress Script";
    
    // Determine file type based on filename extension
    var isTypeScript = Model.FileName.EndsWith(".cy.ts", StringComparison.OrdinalIgnoreCase);
    var languageClass = isTypeScript ? "language-typescript" : "language-javascript";
    var fileExtension = isTypeScript ? ".cy.ts" : ".cy.js";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="User" asp-controller="Project" asp-action="Index">
                <i class="bi bi-folder2-open me-1"></i>My Projects
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-area="User" asp-controller="UserStory" asp-action="Details" asp-route-id="@Model.UserStoryId">@Model.UserStoryTitle</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Review Cypress Script</li>
    </ol>
</nav>

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-file-earmark-code me-2"></i>Review & Export</h1>
        <p class="page-subtitle mb-0">Review and download your generated Cypress script</p>
    </div>
    <div class="page-actions">
        <form asp-action="RunTest" asp-route-id="@Model.Id" method="post" class="d-inline" 
              onsubmit="this.querySelector('button').disabled=true;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">
                <i class="bi bi-play-fill me-1"></i> Run Test
            </button>
        </form>
        <button type="button" class="btn btn-secondary" onclick="copyToClipboard()">
            <i class="bi bi-clipboard me-1"></i> Copy
        </button>
        <form asp-action="Download" asp-route-id="@Model.Id" method="post" class="d-inline">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-download me-1"></i> Download
            </button>
        </form>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-body d-flex flex-wrap gap-4">
        <div>
            <small class="text-muted text-uppercase fw-semibold">User Story</small>
            <p class="mb-0 fw-semibold">@Model.UserStoryTitle</p>
        </div>
        <div>
            <small class="text-muted text-uppercase fw-semibold">File Name</small>
            <p class="mb-0"><code>@Model.FileName</code></p>
        </div>
        <div>
            <small class="text-muted text-uppercase fw-semibold">Target URL</small>
            <p class="mb-0">
                @if (!string.IsNullOrEmpty(Model.TargetUrl))
                {
                    <a href="@Model.TargetUrl" target="_blank">@Model.TargetUrl</a>
                }
                else
                {
                    <span class="text-muted">N/A</span>
                }
            </p>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2">
            <h5 class="mb-0 d-flex align-items-center">
                <i class="bi bi-terminal me-2 text-info"></i> 
                <span class="d-none d-md-inline">Generated Cypress Test Script</span>
                <span class="d-md-none">Cypress Script</span>
            </h5>
            <span class="badge bg-info text-dark cypress-filename-badge">@Model.FileName</span>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="code-toolbar">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="copyToClipboard()">
                    <i class="bi bi-clipboard me-1"></i> Copy
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="selectAll()">
                    <i class="bi bi-check-square me-1"></i> Select All
                </button>
            </div>
            <div class="ms-auto">
                <span class="badge bg-secondary">Lines: @Model.Content.Split('\n').Length</span>
                <span class="badge bg-secondary ms-1">Chars: @Model.Content.Length</span>
            </div>
        </div>

        <pre id="cypressCode" class="code-content m-0"><code class="@languageClass">@Model.Content</code></pre>

        <div id="copySuccessAlert" class="alert alert-success m-2" style="display: none;" role="alert">
            <i class="bi bi-check-circle me-1"></i> Code copied to clipboard!
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Model.TargetUrl))
    {
        <div class="card-footer text-muted">
            <small>
                <i class="bi bi-link-45deg me-1"></i> Target URL: <a href="@Model.TargetUrl" target="_blank">@Model.TargetUrl</a>
            </small>
        </div>
    }
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-arrow-right-circle me-2 text-primary"></i>Next Steps</h5>
    </div>
    <div class="card-body">
        <h6 class="fw-semibold">To use this Cypress test:</h6>
        <ol class="ps-3">
            <li class="mb-2">Download the <code>@fileExtension</code> file using the button above</li>
            <li class="mb-2">Place it in your Cypress project's <code>cypress/e2e/</code> directory</li>
            <li class="mb-2">Ensure Cypress is installed: <code>npm install cypress --save-dev</code></li>
            <li class="mb-2">Run the test: <code>npx cypress run --spec "cypress/e2e/@Model.FileName"</code></li>
        </ol>

        <h6 class="mt-4 fw-semibold">Important Notes:</h6>
        <ul class="ps-3 mb-0">
            <li class="mb-2">Review and adjust selectors if your HTML structure differs</li>
            <li class="mb-2">Update base URLs in your <code>@(isTypeScript ? "cypress.config.ts" : "cypress.config.js")</code> file</li>
            <li class="mb-2">Add any necessary test data or environment variables</li>
            <li>Test the script in your actual environment and refine as needed</li>
        </ul>
    </div>
</div>

<div class="d-flex justify-content-between">
    <a asp-area="User" asp-controller="UserStory" asp-action="Details" asp-route-id="@Model.UserStoryId" 
       class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to User Story
    </a>
    <div>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline"
              onsubmit="return confirm('Are you sure you want to delete this script?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">
                <i class="bi bi-trash me-1"></i> Delete Script
            </button>
        </form>
        <form asp-action="Download" asp-route-id="@Model.Id" method="post" class="d-inline ms-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-download me-1"></i> Download
            </button>
        </form>
    </div>
</div>

<style>
.code-content {
    background-color: #1e293b;
    color: #e2e8f0;
    padding: 1.5rem;
    overflow-x: auto;
    max-height: 600px;
    font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
    font-size: 0.875rem;
    line-height: 1.5;
    border-radius: 0;
}

.code-toolbar {
    background-color: var(--surface-secondary);
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
}


.language-typescript,
.language-javascript {
    display: block;
}

/* Cypress filename badge responsive handling */
.cypress-filename-badge {
    word-break: break-all;
    overflow-wrap: anywhere;
    white-space: normal;
    text-align: left;
    max-width: 100%;
    display: inline-block;
}

    /* Mobile specific adjustments */
    @@media (max-width: 767.98px) {
        .cypress-filename-badge {
            font-size: 0.7rem;
            padding: 0.35rem 0.5rem;
            line-height: 1.3;
            width: 100%;
        }
        
        .card-header .gap-2 {
            gap: 0.5rem !important;
        }
    }

    /* Loading Overlay */
    #loadingOverlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.95));
        z-index: 9999;
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    #loadingOverlay h4 {
        color: #f1f5f9;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    #loadingOverlay p {
        color: #94a3b8;
        font-size: 0.9rem;
    }

    .spinner {
        width: 50px;
        height: 50px;
        border: 5px solid rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        border-top-color: white;
        animation: spin 1s ease-in-out infinite;
        margin-bottom: 20px;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

<div id="loadingOverlay">
    <div class="spinner"></div>
    <h4>Launching Cypress...</h4>
    <p>The test browser window will open shortly.</p>
</div>

<!-- Toast for test launched -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1090;">
    <div id="testLaunchedToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header bg-success text-white">
            <i class="bi bi-play-circle-fill me-2"></i>
            <strong class="me-auto">Cypress Launched</strong>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body">
            <i class="bi bi-display me-1"></i> Watch the Cypress browser window for test execution.
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function copyToClipboard() {
            const codeElement = document.getElementById('cypressCode');
            const text = codeElement.innerText;
            
            try {
                await navigator.clipboard.writeText(text);
                const alertEl = document.getElementById('copySuccessAlert');
                alertEl.style.display = 'block';
                setTimeout(() => {
                    alertEl.style.display = 'none';
                }, 3000);
            } catch (err) {
                console.error('Failed to copy to clipboard:', err);
                window.alert('Failed to copy code. Please select and copy manually.');
            }
        }

        function selectAll() {
            const codeElement = document.getElementById('cypressCode');
            const range = document.createRange();
            range.selectNodeContents(codeElement);
            const selection = window.getSelection();
            selection.removeAllRanges();
            selection.addRange(range);
        }

        function showLoading() {
            document.getElementById('loadingOverlay').style.display = 'flex';
        }

        // Show toast if test was just launched
        document.addEventListener('DOMContentLoaded', () => {
            const params = new URLSearchParams(window.location.search);
            if (params.get('testLaunched') === 'true') {
                const toast = document.getElementById('testLaunchedToast');
                if (toast) {
                    const bsToast = new bootstrap.Toast(toast, { delay: 5000 });
                    bsToast.show();
                }
                // Clean URL
                const url = new URL(window.location);
                url.searchParams.delete('testLaunched');
                window.history.replaceState({}, '', url);
            }
        });
    </script>
}
