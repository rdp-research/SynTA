@model IEnumerable<CypressReviewViewModel>
@{
    ViewData["Title"] = "Cypress Scripts";
    var userStoryId = ViewBag.UserStoryId;
    var userStoryTitle = ViewBag.UserStoryTitle;
    var projectName = ViewBag.ProjectName;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="User" asp-controller="Project" asp-action="Index">
                <i class="bi bi-folder2-open me-1"></i>My Projects
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-area="User" asp-controller="UserStory" asp-action="Details" asp-route-id="@userStoryId">@userStoryTitle</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Cypress Scripts</li>
    </ol>
</nav>

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-terminal me-2"></i>Cypress Test Scripts</h1>
        <p class="page-subtitle mb-0">User Story: <strong>@userStoryTitle</strong></p>
    </div>
    <div class="page-actions">
        @if (Model.Any())
        {
            <form asp-action="DeleteAll" asp-route-userStoryId="@userStoryId" method="post" class="d-inline"
                  onsubmit="return confirm('Are you sure you want to delete ALL Cypress scripts? This action cannot be undone.');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-1"></i> Delete All
                </button>
            </form>
        }
        <a asp-area="User" asp-controller="Gherkin" asp-action="Index" asp-route-userStoryId="@userStoryId" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Gherkin
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">
            <i class="bi bi-terminal"></i>
        </div>
        <h3>No Cypress Scripts Yet</h3>
        <p>Generate executable Cypress tests from your approved Gherkin scenarios!</p>
        <a asp-area="User" asp-controller="Gherkin" asp-action="Index" asp-route-userStoryId="@userStoryId" class="btn btn-primary btn-lg">
            <i class="bi bi-arrow-left me-2"></i>View Gherkin Scenarios
        </a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var script in Model)
        {
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0 text-break" style="word-break: break-word;">
                            <i class="bi bi-file-earmark-code me-2 text-primary"></i>@script.FileName
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6 mb-2 mb-md-0">
                                <small class="text-muted text-uppercase fw-semibold d-block mb-1">Target URL</small>
                                @if (!string.IsNullOrEmpty(script.TargetUrl))
                                {
                                    <a href="@script.TargetUrl" target="_blank" class="text-primary text-decoration-none">
                                        <i class="bi bi-link-45deg me-1"></i>@script.TargetUrl
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">Not specified</span>
                                }
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted text-uppercase fw-semibold d-block mb-1">Created</small>
                                <span><i class="bi bi-clock me-1"></i>@script.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy 'at' h:mm tt")</span>
                            </div>
                        </div>

                        <details class="mb-3">
                            <summary class="btn btn-outline-secondary btn-sm mb-2">
                                <i class="bi bi-code-square me-1"></i> Preview Code
                            </summary>
                            <pre class="code-block mt-2" style="max-height: 300px; overflow-y: auto;">@script.Content</pre>
                        </details>

                        <div class="d-flex gap-2 flex-wrap">
                            <a asp-action="ReviewAndExport" asp-route-id="@script.Id" class="btn btn-primary btn-sm">
                                <i class="bi bi-eye me-1"></i> Review & Export
                            </a>
                            <form asp-action="Download" asp-route-id="@script.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-success btn-sm">
                                    <i class="bi bi-download me-1"></i> Download
                                </button>
                            </form>
                            <form asp-action="Delete" asp-route-id="@script.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Are you sure you want to delete this script?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
